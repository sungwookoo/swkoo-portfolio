# Reference Dockerfile for a small Node.js app on swkoo.kr.
# Save this as `Dockerfile` (no extension) at the root of your repo and
# adjust the four marked spots for your app.

# ── Build stage ──────────────────────────────────────────────
FROM node:20-alpine AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
# (1) If your app has a build step, run it here.
# RUN npm run build

# ── Runtime stage ────────────────────────────────────────────
FROM node:20-alpine AS runtime
WORKDIR /app

# tini is a tiny init that reaps zombies — recommended for Node containers.
RUN apk add --no-cache tini

# (2) Copy only what you need at runtime.
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/package.json ./package.json
COPY --from=build /app/src ./src
# COPY --from=build /app/dist ./dist   # uncomment if you build to dist/

# (3) Run as non-root — swkoo's cluster requires this.
USER node

# (4) Expose the port your app listens on. The Service / Ingress in
# the swkoo manifests must point at the same port.
EXPOSE 3000
ENV NODE_ENV=production
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["node", "src/server.js"]
